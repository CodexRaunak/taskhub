# Application
PORT=3000
APP_NAME=TaskHub
LOG_LEVEL=info
NODE_ENV=development

# Database
DATABASE_URL=postgres://taskhub:taskhub123@postgres:5432/taskhub

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# PostgreSQL container (used by postgres service)
POSTGRES_USER=taskhub
POSTGRES_PASSWORD=taskhub123
POSTGRES_DB=taskhub
